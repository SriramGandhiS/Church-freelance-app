rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all collections for any user (authenticated or not)
    match /{document=**} {
      allow read: if true;
    }
    // Allow write only for authenticated users
    match /{document=**} {
      allow write: if request.auth != null;
    }
  }
}
